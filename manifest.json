{
  "manifest_version": 3,
  "name": "Article to Text",
  "version": "0.5",
  "description": "Extract article content from web pages and convert to clean text for AI tools",
  "permissions": ["activeTab", "scripting"],
  "icons": {
    "48": "icon.png"
  },
  "browser_specific_settings": {
  "gecko": {
    "id": "@article2text",
    "data_collection_permissions": {
      "required": [
        "none"
      ]
    },
    "strict_min_version": "142.0"
  }
 },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icon.png"
    }
  }
}
